# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit secrets.

# GEMINI_API_KEY: Only needed if you add server code that calls the Gemini API
# (e.g. a Route Handler under `app/api/...`). The storefront does not use it yet.
# Paste your key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public base URL of this app (no trailing slash).
# Local dev (default for now):
APP_URL="http://localhost:3000"
# Production example:
# APP_URL="https://razzaqluxe.com"

# Optional: same as APP_URL but exposed to the browser if you ever need it in client code.
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Figma — optional: export design JSON for syncing UI (`npm run figma:export`).
# Personal access token: Figma → Settings → Security → Personal access tokens
# FIGMA_ACCESS_TOKEN="figd_your_token_here"
# Defaults to the file from your design URL if omitted:
# FIGMA_FILE_KEY="EwyQy2kMIy0NFUjdzYHklD"
